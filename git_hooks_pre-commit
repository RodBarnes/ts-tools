#!/usr/bin/env bash

# Git pre-commit hook for ts-tools
# Automatically updates VERSION in any staged script file, and
# TS_SHARED_VERSION in ts-shared.sh, to today's date (YYYYMMDD).
#
# Install: cp ts-tools-pre-commit .git/hooks/pre-commit
#          chmod +x .git/hooks/pre-commit

today=$(date +%Y%m%d)

files=(
  ts-backup.sh
  ts-delete.sh
  ts-list.sh
  ts-restore.sh
)

for file in "${files[@]}"; do
  if git diff --cached --name-only | grep -q "^$file$"; then
    sed -i "s/^VERSION=\"[0-9]\{8\}\"/VERSION=\"$today\"/" "$file"
    git add "$file"
  fi
done

